// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/cpp
{
  "name": "Meshtastic Firmware Dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "installTools": true,
      "version": "3.14"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "platformio.platformio-ide",
        "Trunk.io"
      ],
      "unwantedRecommendations": ["ms-azuretools.vscode-docker"],
      "settings": {
        "extensions.ignoreRecommendations": true
      }
    }
  },

  // Use "--device=" to make a local device available inside the container.
  "runArgs": ["--device=/dev/ttyACM0", "--group-add=dialout"],

  // Expose ports from the container to all network interfaces
  "appPort": ["4403:4403"],

  // Forward ports from the container to the host
  "forwardPorts": [4403],
  "portsAttributes": {
    "4403": {
      "label": "Meshtastic API",
      "onAutoForward": "notify",
      "elevateIfNeeded": true
    }
  },

  // Environment variables for X11 forwarding
  "containerEnv": {
    "DISPLAY": "${localEnv:DISPLAY}"
  },

  // Run commands to prepare the container for use
  "postCreateCommand": ".devcontainer/setup.sh"
}
